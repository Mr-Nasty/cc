- nano install_nginx.yml

Add the following YAML code inside the file:

---
- name: Install and Start NGINX
  hosts: localhost
  become: yes

  tasks:

    - name: Install NGINX
      apt:
        name: nginx
        state: present
        update_cache: yes

    - name: Start Nginx service
      service:
        name: nginx
        state: started

    - name: Create a file
      file:
        path: /home/kali/demo.txt
        state: touch

